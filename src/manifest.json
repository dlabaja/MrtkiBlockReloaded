{
  "manifest_version": 3,
  "name": "MrtkiBlock Reloaded",
  "version": "1.0",
  "description": "Blokování hnoje na webu - rewrite původního rozšíření MrtkiBlock od branik.v.akci",
  "action": {
    "default_popup": "./popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mrtkiblockreloaded@dlabaja.dev",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "all_frames": true,
      "run_at": "document_end",
      "js": ["script.js"]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage"
  ]
}