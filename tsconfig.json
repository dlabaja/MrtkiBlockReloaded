{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "allowJs": true,
    "checkJs": false,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "noEmit": true
  },

  "include": ["src/**/*", "tests/**/*"]
}